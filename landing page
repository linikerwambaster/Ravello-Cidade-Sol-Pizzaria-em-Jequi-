.cta-final h2 em{font-style:italic;color:var(--ouro)}
.cta-final p{max-width:560px;margin:0 auto 40px;color:#e3d8c5}
.cta-final .small{font-family:'Montserrat',sans-serif;font-size:.82rem;color:var(--kraft);margin-top:26px;letter-spacing:.04em}

/* ============ FOOTER ============ */
footer{background:#1c1916;color:#b8ad9a;text-align:center;padding:46px 28px;font-family:'Montserrat',sans-serif}
footer img{max-width:72px;margin:0 auto 18px;opacity:.9}
footer .nome{font-family:'Cinzel',serif;letter-spacing:.22em;color:var(--creme);font-size:.9rem;text-transform:uppercase;margin-bottom:8px}
footer .loc{font-size:.82rem;letter-spacing:.06em;margin-bottom:18px}
footer .mini{font-size:.72rem;color:#6f665a;margin-top:14px}

/* ============ BOTÃO FLUTUANTE ============ */
.float-zap{
  position:fixed;right:22px;bottom:22px;z-index:50;
  width:60px;height:60px;border-radius:50%;
  background:#25D366;display:flex;align-items:center;justify-content:center;
  box-shadow:0 8px 24px rgba(0,0,0,.3);
  animation:pulse 2.4s infinite;
  transition:transform .2s ease;
}
.float-zap:hover{transform:scale(1.08)}
.float-zap svg{width:34px;height:34px;fill:#fff}

/* ============ ANIMAÇÕES ============ */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%{box-shadow:0 8px 24px rgba(0,0,0,.3),0 0 0 0 rgba(37,211,102,.5)}
  70%{box-shadow:0 8px 24px rgba(0,0,0,.3),0 0 0 16px rgba(37,211,102,0)}
  100%{box-shadow:0 8px 24px rgba(0,0,0,.3),0 0 0 0 rgba(37,211,102,0)}}

.reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
.reveal.on{opacity:1;transform:none}

/* ============ RESPONSIVO ============ */
@media(max-width:880px){
  .marca .wrap{grid-template-columns:1fr;gap:42px}
  .marca .selo-box{order:-1}
  .marca .selo-box img{max-width:300px}
  .cards{grid-template-columns:1fr}
  .faixa .grid{gap:34px}
}
@media(max-width:520px){
